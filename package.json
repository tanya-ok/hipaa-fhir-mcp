{
  "name": "hipaa-fhir-mcp",
  "version": "0.3.0",
  "description": "HIPAA-oriented MCP server exposing FHIR R4 tools to AI agents",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "hipaa-fhir-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "audit": "pnpm audit --audit-level moderate",
    "check:phi": "node scripts/check-phi.mjs",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "package:mcpb": "pnpm build && pnpm dlx @anthropic-ai/mcpb pack . hipaa-fhir-mcp.mcpb"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.16.0",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
