# FHIR endpoint. Defaults to the public SMART sandbox; swap for a
# HealthLake FHIR datastore URL in production.
FHIR_BASE_URL=https://r4.smarthealthit.org

# Optional bearer token for authenticated FHIR endpoints.
# In production this is populated from the SMART-on-FHIR token exchange.
# FHIR_AUTH_TOKEN=

# Identity surfaced in every audit record. In production this is replaced
# by the SPIFFE SVID read from the Workload API.
# Defaults to "anonymous-dev" if unset.
CALLER_IDENTITY=local-dev

# Optional file sink for audit records in development.
# If unset, audit records are written to stdout.
# AUDIT_LOG_FILE=./audit-local.log

# development | production | test
NODE_ENV=development

# FHIR request timeout, milliseconds.
REQUEST_TIMEOUT_MS=10000
